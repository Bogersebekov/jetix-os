}

L6: "🎯 6. Strategic layer — decisions/strategic/" {
  style: {fill: "#f3e5f5"; stroke: "#7b1fa2"; stroke-width: 3; border-radius: 8; font-size: 16}

  strategic: "6 doc types:\nLock Entry · North Star ·\nDirection Card · Phase Plan ·\nReflection · Strategic Insight" {style: {fill: "#ffffff"; stroke: "#7b1fa2"}}
}

L7: "🛡 7. Operational" {
  style: {fill: "#fff3e0"; stroke: "#f57c00"; stroke-width: 2; border-radius: 8; font-size: 16}

  claude_md: "CLAUDE.md" {style: {fill: "#ffffff"; stroke: "#f57c00"}}
