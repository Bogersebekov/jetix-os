}

# ────────────────────────────────────────────
# UPWARD FLOWS (each layer → next)
# Каждый transition — через ack/gate
# ────────────────────────────────────────────

L1 -> L2: "ingest" {style: {stroke: "#616161"; stroke-width: 2}}

L2 -> L3: "pipeline\nautomation" {style: {stroke: "#558b2f"; stroke-width: 2}}

L3 -> L4: "🔒 ack →\ndraft promotion" {style: {stroke: "#f9a825"; stroke-width: 2}}

L4 -> L5: "🔒 ack →\nbrigadier promotes\nto canonical" {style: {stroke: "#558b2f"; stroke-width: 2}}

L5 -> L6: "🔒 ack →\nRuslan prose +\nsynthesis" {style: {stroke: "#7b1fa2"; stroke-width: 2}}

L6 -> L7: "config sync\n(Pillar C ↔ CLAUDE.md)" {style: {stroke: "#f57c00"; stroke-width: 2}}

L7 -> L8: "🔒 RT-2 write-ack\n(Phase B)" {style: {stroke: "#c2185b"; stroke-width: 2}}

