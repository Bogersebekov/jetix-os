# Render:
#   d2 --theme=200 --layout=elk v2-data-flow-layers.d2 v2.svg
#   d2 --sketch v2-data-flow-layers.d2 v2-sketch.svg

title: |md
  # Data Flow Layers
  ## Где живут данные — снизу (raw) к верху (output)
| {near: top-center}

direction: up

# ────────────────────────────────────────────
# 8 LAYERS (bottom → top)
# Цвета — canonical Jetix schema из V1
# ────────────────────────────────────────────

L1: "🌐 1. External signals" {
  style: {fill: "#fafafa"; stroke: "#9e9e9e"; stroke-width: 2; border-radius: 8; font-size: 16}

  voice: "🎙 voice memo" {style: {fill: "#ffffff"; stroke: "#9e9e9e"}}
  tg: "💬 Telegram" {style: {fill: "#ffffff"; stroke: "#9e9e9e"}}
  docs: "📄 docs / PDF" {style: {fill: "#ffffff"; stroke: "#9e9e9e"}}
  web: "🌐 web / URLs" {style: {fill: "#ffffff"; stroke: "#9e9e9e"}}
}

L2: "📦 2. Raw layer — raw/" {
  style: {fill: "#eeeeee"; stroke: "#616161"; stroke-width: 2; border-radius: 8; font-size: 16}

  transcripts: "raw/transcripts/" {style: {fill: "#ffffff"; stroke: "#616161"}}
  articles: "raw/articles/" {style: {fill: "#ffffff"; stroke: "#616161"}}
  research: "raw/research/" {style: {fill: "#ffffff"; stroke: "#616161"}}
  books: "raw/books-md/\n402 книги" {style: {fill: "#ffffff"; stroke: "#616161"}}
}

L3: "🚪 3. Triage — Part 2 STOP-gate" {
  style: {fill: "#f1f8e9"; stroke: "#558b2f"; stroke-width: 3; border-radius: 8; font-size: 16}

  pipeline: "transcribe →\nextract →\nfilter →\nreview-report" {style: {fill: "#ffffff"; stroke: "#558b2f"}}
  stop: "⛔ STOP\nhuman ack" {style: {fill: "#ffffff"; stroke: "#f57c00"; stroke-width: 2}}
}

L4: "⚙ 4. Working area" {
  style: {fill: "#fff8e1"; stroke: "#f9a825"; stroke-width: 2; border-radius: 8; font-size: 16}

  drafts: "swarm/wiki/drafts/" {style: {fill: "#ffffff"; stroke: "#f9a825"}}
