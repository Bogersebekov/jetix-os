}

L5: "📚 5. Wiki canonical — Part 3" {
  style: {fill: "#dcedc8"; stroke: "#558b2f"; stroke-width: 3; border-radius: 8; font-size: 16}

  entities: "concepts /\nentities /\nsources / topics" {style: {fill: "#ffffff"; stroke: "#558b2f"}}
