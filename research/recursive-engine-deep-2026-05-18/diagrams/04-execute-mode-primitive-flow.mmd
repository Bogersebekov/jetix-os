%%{init: {'theme':'base', 'themeVariables': {'primaryTextColor':'#000000','textColor':'#000000','lineColor':'#333333','primaryBorderColor':'#333333','primaryColor':'#fafafa','noteTextColor':'#000000','noteBkgColor':'#fff8d5','edgeLabelBackground':'#ffffff'}}}%%
flowchart TD
  start[Ruslan ack received<br/>OR pre-authorized scope]
  start --> E1[E1: Dispatch<br/>brigadier → cells per matrix]
  E1 --> cellWork[Cells execute<br/>within pre-auth scope]
  cellWork --> check{Novel action?<br/>Foundation touch?}
  check -->|Yes| escalate[Plan-mode P5<br/>AWAITING-APPROVAL packet]
  check -->|No, OK| E3[E3: Log append<br/>wiki/log.md + JSONL]
  E3 --> E2[E2: Atomic commit<br/>per-phase format]
  E2 --> hookCheck{Pre-commit hooks<br/>pass?}
  hookCheck -->|No| E5[E5: Halt<br/>R1/R2/R6/R11/IP-1]
  hookCheck -->|Yes| E4[E4: Push origin main]
  E4 --> E8[E8: Reflection trigger<br/>cycle boundary]
  E8 --> nextCycle[Next plan-mode cycle<br/>OR run complete]
  E5 --> halted[Halted<br/>Ruslan escalate]
  escalate --> ruslanAck[Ruslan ack<br/>option A/B/C/deny]
  ruslanAck --> E1
  E6[E6: Pause<br/>cost / time / scope]
  E6 -.monitors.- cellWork
  E7[E7: Resume<br/>last commit checkpoint]
  E6 -.upon resume.-> E7
  E7 -.continue.-> E1

  classDef primitive fill:#dbeafe,color:#1a202c
  classDef gate fill:#fef3c7,color:#1a202c
  classDef halt fill:#fecaca,color:#1a202c
  classDef terminal fill:#bbf7d0,color:#1a202c
  classDef escalate fill:#fde68a,color:#1a202c

  class E1,E2,E3,E4,E6,E7,E8 primitive
  class check,hookCheck gate
  class E5,halted halt
  class nextCycle terminal
  class escalate,ruslanAck escalate
