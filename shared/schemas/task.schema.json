{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JetixTask",
  "type": "object",
  "required": ["id", "created_at", "assigned_to", "status", "title"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task-[0-9]{8}-[0-9]{3,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "assigned_to": {
      "type": "string"
    },
    "assigned_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "done", "blocked", "cancelled"]
    },
    "title": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "normal", "low"]
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "type": "string"
    }
  }
}
